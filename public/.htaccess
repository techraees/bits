<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Agar actual file/folder exist karta ho to use serve karo
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Baaki sare routes index.html ko pass ho jayen
  RewriteRule ^ index.html [L]
</IfModule>

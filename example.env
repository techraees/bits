# BITS Frontend — environment template
# Copy to .env and fill in values. Never commit .env with real secrets.
# CRA only injects variables prefixed with REACT_APP_ at build time.

# --- Backend ---
REACT_APP_BACKEND_BASE_URL=http://localhost:4000

# --- Wallet (Reown) — https://dashboard.reown.com ---
REACT_APP_REOWN_ID=

# --- Infura RPC ---
REACT_APP_INFURA_API_KEY=

# --- Infura IPFS ---
REACT_APP_INFURA=https://ipfs.infura.io:5001/api/v0
REACT_APP_PROJECT_ID=
REACT_APP_PROJECT_SECRET=
REACT_APP_IPFS_PATH=https://infura-ipfs.io/ipfs

# --- Storj public URL (after upload) ---
REACT_APP_STORJ_URL=

# --- Alchemy (Collections owned NFTs) ---
REACT_APP_ALCHEMY_API_KEY=

# --- reCAPTCHA v2 site key (pairs with backend RECAPTCHA_SECRET_KEY) ---
REACT_APP_RECAPTCH_SITE_KEY=

# --- Email / support ---
REACT_APP_EMAIL_OWNER=
REACT_APP_ZENDESK_KEY=

# --- Stripe (public key only) ---
REACT_APP_STRIPE_PUBLIC_KEY=

# --- Chain IDs ---
REACT_APP_ETH_CHAINID=1
